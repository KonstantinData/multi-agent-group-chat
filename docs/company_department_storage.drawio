<mxfile host="app.diagrams.net" version="29.3.0">
  <diagram id="company-dept-storage" name="Company Department Storage">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Company Department — Speicherung der Ergebnisse" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="800" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Welche Daten werden wo gespeichert — von der AG2-Nachricht bis zum downstream Verbraucher. Jedes Department hat ein isoliertes Fach (department_workspaces)." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="40" y="52" width="1400" height="18" as="geometry"/>
        </mxCell>

        <!-- Lane backgrounds -->
        <mxCell id="lane_source" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;" vertex="1" parent="1">
          <mxGeometry x="40" y="82" width="300" height="1060" as="geometry"/>
        </mxCell>
        <mxCell id="lane_method" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;" vertex="1" parent="1">
          <mxGeometry x="380" y="82" width="240" height="1060" as="geometry"/>
        </mxCell>
        <mxCell id="lane_store" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;" vertex="1" parent="1">
          <mxGeometry x="670" y="82" width="460" height="1060" as="geometry"/>
        </mxCell>
        <mxCell id="lane_downstream" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;" vertex="1" parent="1">
          <mxGeometry x="1180" y="82" width="300" height="1060" as="geometry"/>
        </mxCell>

        <!-- Lane labels -->
        <mxCell id="lbl_source" value="Company Department (AG2 GroupChat)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="58" y="94" width="270" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="lbl_method" value="Speichermethode" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="396" y="94" width="210" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="lbl_store" value="ShortTermMemoryStore  +  supervisor_loop" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="686" y="94" width="380" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="lbl_downstream" value="Downstream" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#4c1d95;" vertex="1" parent="1">
          <mxGeometry x="1196" y="94" width="180" height="18" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════
             SOURCE: AG2 GROUP AGENTS
             ══════════════════════════════════════════════ -->

        <!-- Lead init (run start) -->
        <mxCell id="src_lead_init" value="&lt;b&gt;CompanyLead&lt;/b&gt;&lt;br&gt;run() — Departmentlauf startet&lt;br&gt;eröffnet das Department-Fach" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=12;spacing=6;fontColor=#9a3412;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="240" height="70" as="geometry"/>
        </mxCell>

        <!-- Researcher -->
        <mxCell id="src_researcher" value="&lt;b&gt;CompanyResearcher&lt;/b&gt;&lt;br&gt;run_research(task_key)&lt;br&gt;pro Task, max. 3×" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=12;spacing=6;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="60" y="280" width="240" height="80" as="geometry"/>
        </mxCell>

        <!-- Critic -->
        <mxCell id="src_critic" value="&lt;b&gt;CompanyCritic&lt;/b&gt;&lt;br&gt;review_research(task_key)&lt;br&gt;nach jedem Researcher-Run" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=12;spacing=6;fontColor=#713f12;" vertex="1" parent="1">
          <mxGeometry x="60" y="490" width="240" height="80" as="geometry"/>
        </mxCell>

        <!-- Lead finalize -->
        <mxCell id="src_lead" value="&lt;b&gt;CompanyLead&lt;/b&gt;&lt;br&gt;finalize_package()&lt;br&gt;nach allen Tasks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=12;spacing=6;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="60" y="710" width="240" height="80" as="geometry"/>
        </mxCell>

        <!-- supervisor_loop -->
        <mxCell id="src_supervisor" value="&lt;b&gt;supervisor_loop.py&lt;/b&gt;&lt;br&gt;nach department_runtime.run()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=12;spacing=6;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="60" y="910" width="240" height="70" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════
             STORAGE METHODS
             ══════════════════════════════════════════════ -->

        <mxCell id="mth_open_ws" value="&lt;b&gt;open_department_workspace()&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=12;spacing=6;fontColor=#9a3412;" vertex="1" parent="1">
          <mxGeometry x="396" y="172" width="208" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="mth_ingest" value="&lt;b&gt;ingest_worker_report()&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#9a3412&quot;&gt;department=&quot;CompanyDepartment&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=12;spacing=6;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="396" y="300" width="208" height="46" as="geometry"/>
        </mxCell>

        <mxCell id="mth_critic" value="&lt;b&gt;mark_critic_review()&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#9a3412&quot;&gt;department=&quot;CompanyDepartment&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=12;spacing=6;fontColor=#713f12;" vertex="1" parent="1">
          <mxGeometry x="396" y="510" width="208" height="46" as="geometry"/>
        </mxCell>

        <mxCell id="mth_pkg" value="&lt;b&gt;store_department_package()&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=12;spacing=6;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="396" y="720" width="208" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="mth_conv" value="&lt;b&gt;append_department_conversation()&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=12;spacing=6;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="396" y="770" width="208" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="mth_direct" value="&lt;b&gt;Direkte Zuweisung&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=12;spacing=6;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="396" y="928" width="208" height="36" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════
             STORAGE FIELDS
             ══════════════════════════════════════════════ -->

        <!-- Department Workspace (Fach) -->
        <mxCell id="store_workspace" value="&lt;b&gt;department_workspaces[&quot;CompanyDepartment&quot;]&lt;/b&gt; — isoliertes Fach&lt;br&gt;&lt;b&gt;task_outputs&lt;/b&gt; / &lt;b&gt;task_statuses&lt;/b&gt; / &lt;b&gt;critic_approvals&lt;/b&gt;&lt;br&gt;&lt;b&gt;critic_reviews&lt;/b&gt; / &lt;b&gt;accepted_points&lt;/b&gt; / &lt;b&gt;open_points&lt;/b&gt;&lt;br&gt;&lt;b&gt;revision_history&lt;/b&gt; / &lt;b&gt;worker_reports&lt;/b&gt;&lt;br&gt;&lt;b&gt;facts&lt;/b&gt; / &lt;b&gt;sources&lt;/b&gt; / &lt;b&gt;open_questions&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6b7280&quot;&gt;Parallel-sicher — kein anderes Department schreibt hier&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=11;spacing=5;fontColor=#9a3412;align=left;" vertex="1" parent="1">
          <mxGeometry x="690" y="148" width="420" height="108" as="geometry"/>
        </mxCell>

        <!-- Worker report fields (flat store) -->
        <mxCell id="store_worker" value="&lt;b&gt;Flacher Gesamtspeicher (bleibt bestehen)&lt;/b&gt;&lt;br&gt;&lt;b&gt;task_outputs[&quot;company_fundamentals&quot;]&lt;/b&gt; = payload&lt;br&gt;&lt;b&gt;section_outputs[&quot;company_profile&quot;]&lt;/b&gt; = payload&lt;br&gt;&lt;b&gt;worker_reports&lt;/b&gt;.append(vollständiger Report)&lt;br&gt;&lt;b&gt;facts&lt;/b&gt; / &lt;b&gt;sources&lt;/b&gt; / &lt;b&gt;open_questions&lt;/b&gt; / &lt;b&gt;next_actions&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontSize=11;spacing=5;fontColor=#14532d;align=left;" vertex="1" parent="1">
          <mxGeometry x="690" y="290" width="420" height="96" as="geometry"/>
        </mxCell>

        <!-- Critic review fields (flat store) -->
        <mxCell id="store_critic" value="&lt;b&gt;Flacher Gesamtspeicher (bleibt bestehen)&lt;/b&gt;&lt;br&gt;&lt;b&gt;critic_approvals[task_key]&lt;/b&gt; = True / False&lt;br&gt;&lt;b&gt;critic_reviews[task_key]&lt;/b&gt; = vollständiger Review-Dict&lt;br&gt;&lt;b&gt;accepted_points[task_key]&lt;/b&gt; = [&quot;verified_identity&quot;, ...]&lt;br&gt;&lt;b&gt;open_points[task_key]&lt;/b&gt; = [rejected points]&lt;br&gt;&lt;b&gt;task_statuses[task_key]&lt;/b&gt; = &quot;accepted&quot; / &quot;needs_revision&quot;&lt;br&gt;&lt;b&gt;revision_history[task_key]&lt;/b&gt; = [review_v1, review_v2, ...]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefce8;strokeColor=#ca8a04;fontSize=11;spacing=5;fontColor=#713f12;align=left;" vertex="1" parent="1">
          <mxGeometry x="690" y="496" width="420" height="118" as="geometry"/>
        </mxCell>

        <!-- Department package -->
        <mxCell id="store_pkg" value="&lt;b&gt;department_packages[&quot;CompanyDepartment&quot;]&lt;/b&gt;&lt;br&gt;= vollständiges DepartmentPackage (section_payload, completed_tasks,&lt;br&gt;accepted_points, open_questions, sources, visual_focus, autogen_group)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontSize=11;spacing=5;fontColor=#14532d;align=left;" vertex="1" parent="1">
          <mxGeometry x="690" y="712" width="420" height="58" as="geometry"/>
        </mxCell>

        <!-- Conversation -->
        <mxCell id="store_conv" value="&lt;b&gt;department_conversations[&quot;CompanyDepartment&quot;]&lt;/b&gt;&lt;br&gt;= alle AG2-Nachrichten (Lead, Researcher, Critic, Judge, CodingSpecialist)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontSize=11;spacing=5;fontColor=#14532d;align=left;" vertex="1" parent="1">
          <mxGeometry x="690" y="782" width="420" height="50" as="geometry"/>
        </mxCell>

        <!-- supervisor_loop direct -->
        <mxCell id="store_sections" value="&lt;b&gt;sections[&quot;company_profile&quot;]&lt;/b&gt; = section_payload  ← Hauptkanal zur Synthesis&lt;br&gt;&lt;b&gt;department_packages[&quot;CompanyDept&quot;]&lt;/b&gt; = package  ← für Report&lt;br&gt;&lt;b&gt;run_context.active_tasks[*].status&lt;/b&gt; = &quot;accepted&quot; / &quot;conservative&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;spacing=5;fontColor=#1e3a8a;align=left;" vertex="1" parent="1">
          <mxGeometry x="690" y="908" width="420" height="70" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════
             DOWNSTREAM
             ══════════════════════════════════════════════ -->

        <mxCell id="ds_quality" value="&lt;b&gt;build_quality_review()&lt;/b&gt;&lt;br&gt;liest: critic_approvals,&lt;br&gt;task_statuses, sources,&lt;br&gt;open_questions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=12;spacing=6;fontColor=#4c1d95;" vertex="1" parent="1">
          <mxGeometry x="1200" y="496" width="240" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="ds_synthesis" value="&lt;b&gt;build_synthesis_from_memory()&lt;/b&gt;&lt;br&gt;liest: sections[&quot;company_profile&quot;],&lt;br&gt;&quot;industry_analysis&quot;, &quot;market_network&quot;,&lt;br&gt;quality_review, memory_snapshot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=12;spacing=6;fontColor=#4c1d95;" vertex="1" parent="1">
          <mxGeometry x="1200" y="700" width="240" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="ds_report" value="&lt;b&gt;build_report_package()&lt;/b&gt;&lt;br&gt;liest: pipeline_data +&lt;br&gt;department_packages (alle 3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=12;spacing=6;fontColor=#4c1d95;" vertex="1" parent="1">
          <mxGeometry x="1200" y="860" width="240" height="80" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════
             EDGES: Source → Method
             ══════════════════════════════════════════════ -->

        <mxCell id="e_lead_init_open" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#ea580c;endArrow=block;" edge="1" parent="1" source="src_lead_init" target="mth_open_ws">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_res_ingest" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#16a34a;endArrow=block;" edge="1" parent="1" source="src_researcher" target="mth_ingest">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_critic_mth" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#ca8a04;endArrow=block;" edge="1" parent="1" source="src_critic" target="mth_critic">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_lead_pkg" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#16a34a;endArrow=block;" edge="1" parent="1" source="src_lead" target="mth_pkg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_lead_conv" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#16a34a;endArrow=block;" edge="1" parent="1" source="src_lead" target="mth_conv">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_sup_direct" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#2563eb;endArrow=block;" edge="1" parent="1" source="src_supervisor" target="mth_direct">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════
             EDGES: Method → Store (flat)
             ══════════════════════════════════════════════ -->

        <mxCell id="e_open_ws_store" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#ea580c;endArrow=block;" edge="1" parent="1" source="mth_open_ws" target="store_workspace">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_ingest_store" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#16a34a;endArrow=block;" edge="1" parent="1" source="mth_ingest" target="store_worker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_critic_store" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#ca8a04;endArrow=block;" edge="1" parent="1" source="mth_critic" target="store_critic">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_pkg_store" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#16a34a;endArrow=block;" edge="1" parent="1" source="mth_pkg" target="store_pkg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_conv_store" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#16a34a;endArrow=block;" edge="1" parent="1" source="mth_conv" target="store_conv">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_direct_store" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#2563eb;endArrow=block;" edge="1" parent="1" source="mth_direct" target="store_sections">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════
             EDGES: Method → Workspace (Dual-Write, gestrichelt)
             ══════════════════════════════════════════════ -->

        <mxCell id="e_ingest_ws" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#ea580c;dashed=1;endArrow=block;" edge="1" parent="1" source="mth_ingest" target="store_workspace">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_critic_ws" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#ea580c;dashed=1;endArrow=block;" edge="1" parent="1" source="mth_critic" target="store_workspace">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════
             EDGES: Store → Downstream
             ══════════════════════════════════════════════ -->

        <mxCell id="e_worker_quality" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#7c3aed;dashed=1;endArrow=block;" edge="1" parent="1" source="store_worker" target="ds_quality">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_critic_quality" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#7c3aed;dashed=1;endArrow=block;" edge="1" parent="1" source="store_critic" target="ds_quality">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_sections_synthesis" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#7c3aed;endArrow=block;" edge="1" parent="1" source="store_sections" target="ds_synthesis">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_pkg_report" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#7c3aed;dashed=1;endArrow=block;" edge="1" parent="1" source="store_pkg" target="ds_report">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_sections_report" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#7c3aed;dashed=1;endArrow=block;" edge="1" parent="1" source="store_sections" target="ds_report">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
