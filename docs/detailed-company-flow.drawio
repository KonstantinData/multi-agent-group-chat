        <!-- PATH B: RETRY -->
        <mxCell id="pB" value="&lt;b&gt;PATH B — REJECTED → Retry&lt;/b&gt;&lt;br&gt;approved=false, attempt &lt; MAX_TASK_RETRIES (2)&lt;br&gt;Lead calls request_supervisor_revision(task_key)&lt;br&gt;agents/supervisor.py → decide_revision() → retry=true&lt;br&gt;sets revision_request, workflow_step → &quot;research&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=12;spacing=8;fontColor=#7f1d1d;" vertex="1" parent="1"><mxGeometry x="1170" y="2880" width="360" height="90" as="geometry" /></mxCell>

